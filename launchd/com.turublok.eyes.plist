<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.turublok.eyes</string>

    <key>ProgramArguments</key>
    <array>
        <string>__BINARY_PATH__</string>
        <string>--watch-eyes</string>
    </array>

    <!-- Jam kerja: 08:00 - 22:30 (1 jam buffer sebelum bedtime lock jam 23:00). -->
    <key>StartCalendarInterval</key>
    <array>
        <dict><key>Hour</key><integer>8</integer><key>Minute</key><integer>0</integer></dict>
    </array>

    <key>RunAtLoad</key>
    <false/>

    <!-- Keep alive selama jam kerja. Kalau di-kill, restart sampai 22:30. -->
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>ThrottleInterval</key>
    <integer>30</integer>

    <key>StandardOutPath</key>
    <string>__HOME__/Projects/TURU-BLOK/logs/eyes.out.log</string>

    <key>StandardErrorPath</key>
    <string>__HOME__/Projects/TURU-BLOK/logs/eyes.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>TZ</key>
        <string>Asia/Jakarta</string>
    </dict>
</dict>
</plist>
